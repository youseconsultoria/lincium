# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_CALLBACK_URL=http://localhost:8001/callback

# Sessão (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key

# Domínio SQL Server (acesso via ODBC)
DOMINIO_SERVER=localhost
DOMINIO_DATABASE=dominio_db
DOMINIO_USERNAME=user
DOMINIO_PASSWORD=password
DOMINIO_DRIVER=ODBC Driver 17 for SQL Server

# PostgreSQL (banco do Lincium)
LINCIUM_DB_URL=postgresql://user:password@localhost:5432/lincium

# Ambiente
ENV=development
